{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "pixelduo",
  "main": "worker.js",
  "compatibility_date": "2026-05-11",
  "observability": {
    "enabled": true
  },
  "assets": {
    "not_found_handling": "single-page-application"
  },
  "kv_namespaces": [
    {
      "binding": "RATE_LIMIT",
      "id": "bcdd66539f774e9aaccaacee407dc2ea"
    }
  ],
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
